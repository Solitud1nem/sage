# Deploy configuration — copy to .env and fill in values

# Deployer private key (funded with ETH on target chain)
DEPLOYER_PRIVATE_KEY=0x...

# USDC address on target chain
# Base Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Base Mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Owner address for AgentRegistry emergency pause
REGISTRY_OWNER=0x...

# RPC URLs
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org

# Basescan API key (for contract verification)
BASESCAN_API_KEY=...

# Post-deploy: fill in after deployment
REGISTRY_ADDRESS=
ESCROW_ADDRESS=
