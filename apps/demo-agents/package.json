{
  "name": "@sage/demo-agents",
  "version": "0.0.1",
  "description": "Reference implementation — Orchestrator, Summarizer, Translator demo agents",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev:orchestrator": "node --env-file-if-exists=.env.orchestrator --import tsx src/orchestrator/server.ts",
    "dev:summarizer":   "node --env-file-if-exists=.env.summarizer   --import tsx src/summarizer/agent.ts",
    "dev:translator":   "node --env-file-if-exists=.env.translator   --import tsx src/translator/agent.ts",
    "bootstrap": "bash scripts/bootstrap-local.sh",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sage/adapter-evm": "workspace:*",
    "@sage/core": "workspace:*",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
