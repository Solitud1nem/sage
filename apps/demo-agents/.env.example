# Common env template. For per-service setup, run `pnpm bootstrap` which
# generates .env.orchestrator / .env.summarizer / .env.translator automatically.

# Private key for this service (each service must have its own key).
PRIVATE_KEY=0x...

# Derived address (cast wallet address $PRIVATE_KEY). Optional — helper only.
AGENT_ADDRESS=0x...

# Chain: Base Sepolia by default for local dev. Mainnet via fly-deploy only.
RPC_URL=https://sepolia.base.org

# Service port.
PORT=3000

# Orchestrator only — registered agent addresses.
# SUMMARIZER_ADDRESS=0x...
# TRANSLATOR_ADDRESS=0x...

# Optional — OpenAI fallback for mock responses.
# OPENAI_API_KEY=

# Orchestrator CORS allow-list (web-frontend origins).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Minimum sponsor USDC balance (6 decimals); below this, orchestrator rejects new runs.
# Default: 5 USDC = 5000000. 0 disables the check.
# SPONSOR_MIN_BALANCE_USDC=0
