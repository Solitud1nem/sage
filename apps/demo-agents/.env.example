# Demo agents configuration
# Copy to .env and fill in values

# Private key for the agent (each agent should use its own key in production)
PRIVATE_KEY=0x...

# RPC URL (defaults to Base Sepolia public RPC)
RPC_URL=https://sepolia.base.org

# OpenAI API key (optional — without it, agents use mock responses)
OPENAI_API_KEY=

# Orchestrator-specific: addresses of worker agents
SUMMARIZER_ADDRESS=0x...
TRANSLATOR_ADDRESS=0x...

# Task amount in USDC smallest unit (1000 = 0.001 USDC)
TASK_AMOUNT=1000
