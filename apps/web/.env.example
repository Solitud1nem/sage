# Sage web — env template
# Copy to .env.local for local dev. Do not commit .env.local.

# Public API URL (Cloudflare Pages → Worker RPC proxy → Alchemy).
# In local dev you can point at https://mainnet.base.org directly.
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org

# WalletConnect project ID (https://cloud.walletconnect.com).
# Required for ConnectKit WalletConnect option.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Orchestrator backend (Fly.io) base URL.
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:3000

# PostHog — loaded lazily after consent.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — optional, for client error tracking.
NEXT_PUBLIC_SENTRY_DSN=

# Registered agent addresses for "Try with wallet" demo mode (M-INT.6).
# These are the executor addresses users will target when they run the demo
# from their own wallet. Leave unset to disable wallet mode (Watch live still
# works from the orchestrator backend).
NEXT_PUBLIC_DEMO_SUMMARIZER_ADDRESS=
NEXT_PUBLIC_DEMO_TRANSLATOR_ADDRESS=
